# Local engine server target used by Vite proxy (/engine-api -> this URL)
ENGINE_PROXY_TARGET=http://127.0.0.1:8765

# Optional extra host allowlist for Vite dev server (comma separated)
# VITE_ALLOWED_HOSTS=.example.com,.example2.com

# Optional direct engine API URL override for frontend fetch.
# Leave this unset in ngrok share mode so same-origin proxy is used.
# VITE_ENGINE_API_URL=https://your-engine-domain.example
